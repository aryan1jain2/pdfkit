{
  "name": "pdfkit-client",
  "version": "0.1.0",
  "description": "Client-side .pptx and .xlsx to PDF conversion — no server required",
  "main":   "dist/index.umd.js",
  "module": "dist/index.esm.js",
  "types":  "dist/index.d.ts",
  "exports": {
    ".": {
      "import":  "./dist/index.esm.js",
      "require": "./dist/index.umd.js",
      "types":   "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build":     "vite build",
    "dev":       "vite",
    "test":      "vitest run",
    "test:watch":"vitest",
    "coverage":  "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": ["pdf", "pptx", "xlsx", "converter", "browser", "client-side", "no-server"],
  "license": "MIT",
  "peerDependencies": {
    "jszip": ">=3.0.0",
    "jspdf": ">=2.0.0"
  },
  "devDependencies": {
    "typescript":       "^5.4.0",
    "vite":             "^5.2.0",
    "vitest":           "^1.5.0",
    "vite-plugin-dts":  "^3.9.0",
    "@vitest/coverage-v8": "^1.5.0",
    "jsdom":            "^24.0.0",
    "jszip":            "^3.10.1",
    "jspdf":            "^2.5.1"
  }
}
